# Enphase Enlighten credentials (same account as claude-enphase)
ENPHASE_EMAIL=your@email.com
ENPHASE_PASSWORD=yourpassword

# Enphase site ID — default matches the ALDARONDO site
ENPHASE_SITE_ID=3687112

# JuiceBox MCP server SSE endpoint (running on your Synology NAS)
JUICEBOX_MCP_URL=http://<YOUR-NAS-IP>:3001/sse

# claude-email MCP server SSE endpoint — used to alert on failed battery-mode switches
EMAIL_MCP_URL=http://<YOUR-NAS-IP>:8768/sse
# API key for brian-email auth — must match MCP_API_KEY in brian-email/.env
EMAIL_MCP_API_KEY=
ALERT_TO_EMAIL=charles.aldarondo@gmail.com
